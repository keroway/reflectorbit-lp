{
  "name": "reflectorbit-lp",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.0.8",
  "homepage": "https://reflectorbit-lp.pages.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keroway/reflectorbit-lp.git"
  },
  "bugs": {
    "url": "https://github.com/keroway/reflectorbit-lp/issues"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "typecheck": "astro check",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome check . && prettier --check \"**/*.md\"",
    "format": "biome format --write . && prettier --write \"**/*.md\"",
    "format:biome": "biome format --write .",
    "format:prettier": "prettier --write \"**/*.md\"",
    "og:gen": "node scripts/gen-og.mjs",
    "video:howtoplay:gen": "node scripts/gen-how-to-play-video.mjs",
    "test": "playwright test",
    "smoke": "playwright test tests/smoke.test.ts",
    "smoke:a11y": "playwright test tests/a11y.test.ts",
    "postinstall": "lefthook install"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.3",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.5",
    "@playwright/test": "^1.61.1",
    "hyperframes": "0.7.68",
    "lefthook": "^2.1.10",
    "prettier": "^3.9.6",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "yaml": "^2.8.3"
    }
  }
}
