---
import {
  DOWNLOAD_URL,
  PLAY_URL,
  RELEASE_AVAILABLE,
  downloads,
} from '../consts';
---

{/* ===== Download ===== */}
<section id="download" class="reveal scroll-mt-20 border-t border-white/5 py-24">
  <p class="eyebrow">Download</p>
  <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">ネイティブ版</h2>
  <ul class="mt-8 grid gap-4 sm:grid-cols-3">
    {
      downloads.map((d) => (
        <li class="rounded-lg border border-white/10 p-5">
          <p class="font-semibold text-rb-muted">{d.os}</p>
          <p class="mt-1 font-mono text-sm break-all text-rb-muted/60">{d.file}</p>
        </li>
      ))
    }
  </ul>
  {
    RELEASE_AVAILABLE ? (
      <>
        <a class="btn-primary mt-8 inline-block" href={DOWNLOAD_URL}>最新リリースを見る</a>
        <p class="mt-4 text-sm text-rb-muted/70">
          ※ 配布バイナリは未署名のため初回起動時に OS 警告が出る場合がある（手順は本体 README 参照）。
        </p>
      </>
    ) : (
      <>
        <span
          class="btn-primary mt-8 inline-block cursor-not-allowed opacity-60"
          aria-disabled="true"
          title="本体リリース公開後に有効化されます">
          最新リリースを見る（近日公開）
        </span>
        <p class="mt-4 text-sm text-rb-muted/70">
          ネイティブ版は近日公開予定。今は
          <a class="underline hover:text-rb-core" href={PLAY_URL}>ブラウザ版</a>
          で遊べる。
        </p>
      </>
    )
  }
</section>
