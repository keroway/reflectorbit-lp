---
import { controls } from '../consts';
---

{/* ===== How to Play ===== */}
<section id="how-to-play" class="reveal scroll-mt-20 border-t border-white/5 py-24">
  <p class="eyebrow">How to Play</p>
  <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">←/→ で回転、Space/Shift で軌道半径——3 キー操作</h2>
  <div class="mt-8 overflow-hidden rounded-lg border border-white/10">
    <table class="w-full text-left">
      <tbody>
        {
          controls.map((c) => (
            <tr class="border-b border-white/5 last:border-0">
              <th class="w-40 bg-white/5 px-5 py-4 font-mono text-rb-core">{c.key}</th>
              <td class="px-5 py-4">{c.desc}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
  <p class="mt-4 text-sm text-rb-muted/70">
    物理メモ: 軌道は角運動量保存（&omega; = L / r&sup2;）。半径を縮めるほど速く回る。
    Web 版はタッチ / ポインタ操作にも対応。
  </p>

  {/* Space=縮小 / Shift=拡大 の対比を示す動く図解（HyperFrames 生成） */}
  <figure class="mt-10">
    <div class="relative aspect-video w-full overflow-hidden rounded-lg border border-white/10">
      <video
        class="how-to-play-video h-full w-full object-cover"
        muted
        loop
        playsinline
        controls
        poster="/videos/how-to-play-poster.jpg"
        aria-label="SPACE キーで軌道半径を縮小して高速回転、SHIFT キーで軌道半径を拡大して低速回転する図解動画"
      >
        <source src="/videos/how-to-play.webm" type="video/webm" />
        <source src="/videos/how-to-play.mp4" type="video/mp4" />
      </video>
    </div>
    <figcaption class="mt-3 text-center text-sm text-rb-muted/70">
      角運動量保存 &omega; = L / r&sup2; — r を能動的に変えてタイミングを作る。
    </figcaption>
  </figure>
</section>

<script>
  /*
   * How to Play の動く図解 (<video>) を prefers-reduced-motion に応じて制御する。
   * 通常時は autoplay + loop で即時ロード・再生する。
   * reduced-motion 時は autoplay を行わず、controls を出して静止画 (poster) のみ表示し
   * ユーザーが望めば手動再生できるようにする（Hero.astro の pauseAnimations() 分岐と同様の考え方）。
   */
  const howToPlayVideo = document.querySelector<HTMLVideoElement>('.how-to-play-video');

  if (howToPlayVideo) {
    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');

    function applyMotionPreference(reduced: boolean) {
      if (reduced) {
        howToPlayVideo!.removeAttribute('autoplay');
        howToPlayVideo!.removeAttribute('loop');
        howToPlayVideo!.setAttribute('controls', '');
        howToPlayVideo!.pause();
      } else {
        howToPlayVideo!.removeAttribute('controls');
        howToPlayVideo!.setAttribute('autoplay', '');
        howToPlayVideo!.setAttribute('loop', '');
        void howToPlayVideo!.play().catch(() => {});
      }
    }

    applyMotionPreference(mq.matches);

    mq.addEventListener('change', (e) => applyMotionPreference(e.matches));
  }
</script>
