---
import { PLAY_URL, RELEASE_AVAILABLE, REPO_FALLBACK_URL, REPO_URL } from '../consts';

// 本体リポは公開までは到達不能 URL を踏ませない。
// 公開前は作者アカウント（200 OK）へフォールバックさせる。
const repoHref = RELEASE_AVAILABLE ? REPO_URL : REPO_FALLBACK_URL;
const repoLabel = RELEASE_AVAILABLE ? 'ゲーム本体リポジトリ' : '制作者 GitHub';
---

{/* ===== Footer ===== */}
<footer class="mx-auto max-w-5xl border-t border-white/5 px-6 py-12 text-sm text-rb-muted/60">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <p>制作: keroway</p>
    <nav class="flex gap-6">
      <a
        class="rounded-sm hover:text-rb-core focus-visible:text-rb-core focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-rb-core"
        href={repoHref}>{repoLabel}</a>
      <a
        class="rounded-sm hover:text-rb-core focus-visible:text-rb-core focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-rb-core"
        href={PLAY_URL}>ブラウザで遊ぶ</a>
    </nav>
  </div>
</footer>
