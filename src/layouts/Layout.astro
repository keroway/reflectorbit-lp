---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'REFLECTORBIT — 2 キーで操る軌道反射アクション',
  description = '中心の Core を周回する Shield でメテオを反射し、敵 Spawner を破壊する軌道アクション。Space と Shift の 2 キー操作。ブラウザで今すぐプレイ。',
} = Astro.props;

// canonical / OGP は site + 現在パスから生成 (site 未設定時は undefined)
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : undefined;
const ogImage = Astro.site
  ? new URL('og-default.png', Astro.site).href
  : undefined;

// JSON-LD: ゲーム本体 (Zig 製ネイティブ + WebAssembly ブラウザ版) を VideoGame として記述。
// ブラウザ版のプレイ URL は playMode → SinglePlayer / gamePlatform で示す。
// 出所は docs/copy.md と本体リポジトリ (https://github.com/keroway/reflectorbit)。
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: 'REFLECTORBIT',
  alternateName: 'Reflectorbit',
  description,
  url: Astro.site?.href,
  image: ogImage,
  inLanguage: 'ja',
  genre: ['Action', 'Arcade'],
  gamePlatform: ['Web browser', 'Linux', 'macOS', 'Windows'],
  operatingSystem: ['Linux', 'macOS', 'Windows', 'Web'],
  applicationCategory: 'Game',
  author: {
    '@type': 'Person',
    name: 'keroway',
    url: 'https://github.com/keroway',
  },
  publisher: {
    '@type': 'Person',
    name: 'keroway',
    url: 'https://github.com/keroway',
  },
  sameAs: ['https://github.com/keroway/reflectorbit'],
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'JPY',
    availability: 'https://schema.org/InStock',
    url: 'https://reflectorbit.pages.dev',
  },
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="REFLECTORBIT" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    {
      ogImage && (
        <>
          <meta property="og:image" content={ogImage} />
          <meta property="og:image:type" content="image/png" />
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
          <meta property="og:image:alt" content="REFLECTORBIT — 2 キーで操る軌道反射アクション" />
        </>
      )
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <meta name="generator" content={Astro.generator} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-screen bg-rb-bg text-rb-muted antialiased">
    <slot />
  </body>
</html>
