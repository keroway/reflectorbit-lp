---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'REFLECTORBIT — 2 キーで操る軌道反射アクション',
  description = '中心の Core を周回する Shield でメテオを反射し、敵 Spawner を破壊する軌道アクション。Space と Shift の 2 キー操作。ブラウザで今すぐプレイ。',
} = Astro.props;

// canonical / OGP は site + 現在パスから生成 (site 未設定時は undefined)
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : undefined;
const ogImage = Astro.site
  ? new URL('og-default.png', Astro.site).href
  : undefined;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="min-h-screen bg-rb-bg text-rb-muted antialiased">
    <slot />
  </body>
</html>
