---
import Layout from '../layouts/Layout.astro';

// 外部リンク (docs/copy.md の CTA / Download セクションが正典)
const PLAY_URL = 'https://reflectorbit.pages.dev';
const DOWNLOAD_URL = 'https://github.com/keroway/reflectorbit/releases/latest';
const REPO_URL = 'https://github.com/keroway/reflectorbit';

// 操作方法 (docs/copy.md の How to Play より)
const controls = [
  { key: 'Space', desc: '軌道半径を縮小（角速度が上がる）' },
  { key: 'Shift', desc: '軌道半径を拡大（角速度が下がる）' },
  { key: 'P', desc: 'ポーズ / 再開' },
  { key: '↑ / ↓', desc: 'タイトルで難易度選択' },
];

// ダウンロード (docs/copy.md の Download より)
const downloads = [
  { os: 'Linux (x86_64)', file: 'reflectorbit-linux-x86_64' },
  { os: 'macOS (Apple Silicon)', file: 'reflectorbit-macos-aarch64' },
  { os: 'Windows (x86_64)', file: 'reflectorbit-windows-x86_64.exe' },
];
---

<Layout>
  <main class="mx-auto max-w-5xl px-6">
    {/* ===== Hero ===== */}
    <section class="flex min-h-screen flex-col items-center justify-center text-center">
      <p class="eyebrow">Reflect &times; Orbit</p>
      <h1 class="mt-4 text-5xl font-bold tracking-[0.15em] text-rb-core sm:text-7xl">
        REFLECTORBIT
      </h1>
      <p class="mt-6 text-2xl font-semibold text-rb-shield sm:text-3xl">
        弾くな、撃ち返せ。
      </p>
      <p class="mt-3 max-w-xl text-lg text-rb-muted">
        2 キーで操る、軌道反射アクション。Space と Shift。たった 2 つで宇宙を弾く。
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a class="btn-primary" href={PLAY_URL}>&#9654; ブラウザで今すぐプレイ</a>
        <a class="btn-ghost" href={DOWNLOAD_URL}>ネイティブ版をダウンロード</a>
      </div>
      {/* TODO: 反射シーンのループ動画 / スクショを背景に敷く (docs/assets.md) */}
    </section>

    {/* ===== Concept ===== */}
    <section class="border-t border-white/5 py-24">
      <p class="eyebrow">Concept</p>
      <h2 class="mt-3 text-3xl font-bold text-rb-muted sm:text-4xl">
        「守る」だけでなく「反射して攻撃する」
      </h2>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed">
        中心の <span class="text-rb-core">Core</span> を周回する
        <span class="text-rb-shield">Shield</span> を操り、重力に引かれて加速する
        <span class="text-rb-meteor">Meteor</span> を反射。弾き返したメテオを画面外の
        <span class="text-rb-danger">Spawner</span> にぶつけて破壊する——軌道アクション。
      </p>
      <ul class="mt-8 grid gap-4 sm:grid-cols-2">
        <li class="rounded-lg border border-white/5 p-5">
          <span class="font-semibold text-rb-core">2 キー操作</span>で軌道半径を能動的にコントロール
        </li>
        <li class="rounded-lg border border-white/5 p-5">
          「ただ防ぐ」ではなく<span class="font-semibold text-rb-shield">「反射 → 攻撃」</span>という能動的フック
        </li>
        <li class="rounded-lg border border-white/5 p-5">
          連鎖（<span class="font-semibold text-rb-combo">誘爆コンボ</span>）による爽快感
        </li>
        <li class="rounded-lg border border-white/5 p-5">
          可変軌道半径 &times; メテオ重力加速による「タイミングと距離感の二重読み合い」
        </li>
      </ul>

      {/* コアフック図解: Shield が Meteor を Spawner へ反射する */}
      <figure class="mt-10">
        <svg
          viewBox="0 0 400 240"
          class="mx-auto block h-auto w-full max-w-2xl"
          role="img"
          aria-labelledby="concept-diagram-title concept-diagram-desc"
        >
          <title id="concept-diagram-title">コアフック図解</title>
          <desc id="concept-diagram-desc">
            中心の Core を周回する Shield が、飛来する Meteor を反射して画面外の Spawner にぶつけて破壊する流れ。
          </desc>

          {/* 軌道 (破線円): 中心 (170, 135) 半径 62 */}
          <circle
            cx="170"
            cy="135"
            r="62"
            fill="none"
            stroke="var(--color-rb-core)"
            stroke-opacity="0.35"
            stroke-width="1"
            stroke-dasharray="3 4"
          />

          {/* Meteor の入射軌跡 (外から反射点 170,73 へ) */}
          <path
            d="M40 40 L170 73"
            stroke="var(--color-rb-meteor)"
            stroke-width="1.5"
            stroke-dasharray="4 4"
            fill="none"
          />

          {/* Shield → Spawner への反射軌跡 (170,73 から右上の Spawner へ) */}
          <path
            d="M170 73 L340 30"
            stroke="var(--color-rb-shield)"
            stroke-width="1.5"
            stroke-dasharray="4 4"
            fill="none"
          />

          {/* Shield 弧 (軌道上のマゼンタの弧、上端 215°→325° を通る) */}
          <path
            d="M119.2 99.4 A62 62 0 0 1 220.8 99.4"
            fill="none"
            stroke="var(--color-rb-shield)"
            stroke-width="6"
            stroke-linecap="round"
          />

          {/* 反射点で光る火花 (軌道の頂点) */}
          <circle cx="170" cy="73" r="7" fill="var(--color-rb-spark)" fill-opacity="0.3" />
          <circle cx="170" cy="73" r="3" fill="var(--color-rb-spark)" />

          {/* Core */}
          <circle cx="170" cy="135" r="20" fill="var(--color-rb-core)" fill-opacity="0.18" />
          <circle cx="170" cy="135" r="10" fill="var(--color-rb-core)" />

          {/* Meteor */}
          <circle cx="40" cy="40" r="8" fill="var(--color-rb-meteor)" />

          {/* Spawner (画面外の発生源) */}
          <g>
            <circle cx="345" cy="28" r="13" fill="none" stroke="var(--color-rb-danger)" stroke-width="2" />
            <circle cx="345" cy="28" r="5" fill="var(--color-rb-danger)" />
          </g>

          {/* ラベル */}
          <g font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="11">
            <text x="170" y="225" fill="var(--color-rb-core)" text-anchor="middle">CORE</text>
            <text x="170" y="55" fill="var(--color-rb-shield)" text-anchor="middle">SHIELD</text>
            <text x="40" y="22" fill="var(--color-rb-meteor)" text-anchor="middle">METEOR</text>
            <text x="345" y="60" fill="var(--color-rb-danger)" text-anchor="middle">SPAWNER</text>
            <text x="260" y="62" fill="var(--color-rb-muted)" fill-opacity="0.7" text-anchor="middle">反射 →</text>
          </g>
        </svg>
        <figcaption class="mt-3 text-center text-sm text-rb-muted/70">
          Shield で Meteor を弾き、画面外の Spawner にぶつけて破壊する。
        </figcaption>
      </figure>
    </section>

    {/* ===== How to Play ===== */}
    <section class="border-t border-white/5 py-24">
      <p class="eyebrow">How to Play</p>
      <h2 class="mt-3 text-3xl font-bold text-rb-muted sm:text-4xl">Space と Shift の 2 キー</h2>
      <div class="mt-8 overflow-hidden rounded-lg border border-white/10">
        <table class="w-full text-left">
          <tbody>
            {
              controls.map((c) => (
                <tr class="border-b border-white/5 last:border-0">
                  <th class="w-40 bg-white/5 px-5 py-4 font-mono text-rb-core">{c.key}</th>
                  <td class="px-5 py-4">{c.desc}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-sm text-rb-muted/70">
        物理メモ: 軌道は角運動量保存（&omega; = L / r&sup2;）。半径を縮めるほど速く回る。
        Web 版はタッチ / ポインタ操作にも対応。
      </p>

      {/* Space=縮小 / Shift=拡大 の対比図解 */}
      <figure class="mt-10">
        <div class="grid gap-6 sm:grid-cols-2">
          {/* Space: 軌道半径を縮小 → 高速回転 */}
          <div class="rounded-lg border border-white/5 p-5">
            <p class="font-mono text-sm text-rb-core">SPACE — 縮小</p>
            <svg
              viewBox="0 0 200 160"
              class="mt-3 block h-auto w-full"
              role="img"
              aria-label="Space キーで軌道半径を縮小すると角速度が上がる図"
            >
              {/* 外側の元軌道 (薄い破線) */}
              <circle
                cx="100"
                cy="80"
                r="55"
                fill="none"
                stroke="var(--color-rb-core)"
                stroke-opacity="0.2"
                stroke-width="1"
                stroke-dasharray="3 4"
              />
              {/* 縮小後軌道 */}
              <circle
                cx="100"
                cy="80"
                r="32"
                fill="none"
                stroke="var(--color-rb-core)"
                stroke-opacity="0.5"
                stroke-width="1"
                stroke-dasharray="3 4"
              />
              {/* 内向き矢印 (半径方向) */}
              <g stroke="var(--color-rb-core)" stroke-width="1.5" fill="none">
                <path d="M155 80 L132 80" marker-end="url(#arrow-cyan)" />
                <path d="M45 80 L68 80" marker-end="url(#arrow-cyan)" />
              </g>
              {/* Core */}
              <circle cx="100" cy="80" r="6" fill="var(--color-rb-core)" />
              {/* Shield (内側軌道上) */}
              <circle cx="132" cy="80" r="5" fill="var(--color-rb-shield)" />
              {/* 角速度ラベル */}
              <g font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="11">
                <text x="100" y="148" fill="var(--color-rb-combo)" text-anchor="middle">&#969; 大 (速い)</text>
              </g>
              <defs>
                <marker
                  id="arrow-cyan"
                  viewBox="0 0 10 10"
                  refX="8"
                  refY="5"
                  markerWidth="6"
                  markerHeight="6"
                  orient="auto-start-reverse"
                >
                  <path d="M0 0 L10 5 L0 10 z" fill="var(--color-rb-core)" />
                </marker>
              </defs>
            </svg>
            <p class="mt-3 text-sm text-rb-muted/80">
              軌道半径 <span class="text-rb-core">r</span> が小さくなり、角速度 <span class="text-rb-combo">&omega;</span> が上がる。
            </p>
          </div>

          {/* Shift: 軌道半径を拡大 → 低速回転 */}
          <div class="rounded-lg border border-white/5 p-5">
            <p class="font-mono text-sm text-rb-shield">SHIFT — 拡大</p>
            <svg
              viewBox="0 0 200 160"
              class="mt-3 block h-auto w-full"
              role="img"
              aria-label="Shift キーで軌道半径を拡大すると角速度が下がる図"
            >
              {/* 内側の元軌道 (薄い破線) */}
              <circle
                cx="100"
                cy="80"
                r="32"
                fill="none"
                stroke="var(--color-rb-shield)"
                stroke-opacity="0.2"
                stroke-width="1"
                stroke-dasharray="3 4"
              />
              {/* 拡大後軌道 */}
              <circle
                cx="100"
                cy="80"
                r="55"
                fill="none"
                stroke="var(--color-rb-shield)"
                stroke-opacity="0.5"
                stroke-width="1"
                stroke-dasharray="3 4"
              />
              {/* 外向き矢印 (半径方向) */}
              <g stroke="var(--color-rb-shield)" stroke-width="1.5" fill="none">
                <path d="M132 80 L155 80" marker-end="url(#arrow-magenta)" />
                <path d="M68 80 L45 80" marker-end="url(#arrow-magenta)" />
              </g>
              {/* Core */}
              <circle cx="100" cy="80" r="6" fill="var(--color-rb-core)" />
              {/* Shield (外側軌道上) */}
              <circle cx="155" cy="80" r="5" fill="var(--color-rb-shield)" />
              {/* 角速度ラベル */}
              <g font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="11">
                <text x="100" y="148" fill="var(--color-rb-muted)" text-anchor="middle">&#969; 小 (遅い)</text>
              </g>
              <defs>
                <marker
                  id="arrow-magenta"
                  viewBox="0 0 10 10"
                  refX="8"
                  refY="5"
                  markerWidth="6"
                  markerHeight="6"
                  orient="auto-start-reverse"
                >
                  <path d="M0 0 L10 5 L0 10 z" fill="var(--color-rb-shield)" />
                </marker>
              </defs>
            </svg>
            <p class="mt-3 text-sm text-rb-muted/80">
              軌道半径 <span class="text-rb-shield">r</span> が大きくなり、角速度 <span class="text-rb-muted">&omega;</span> が下がる。
            </p>
          </div>
        </div>
        <figcaption class="mt-3 text-center text-sm text-rb-muted/70">
          角運動量保存 &omega; = L / r&sup2; — r を能動的に変えてタイミングを作る。
        </figcaption>
      </figure>
    </section>

    {/* ===== Playable Demo (将来) ===== */}
    <section class="border-t border-white/5 py-24">
      <p class="eyebrow">Playable Demo</p>
      <h2 class="mt-3 text-3xl font-bold text-rb-muted/60 sm:text-4xl">その場で試遊（準備中）</h2>
      <div class="mt-8 flex aspect-video w-full items-center justify-center rounded-lg border border-dashed border-white/15 text-rb-muted/50">
        WASM 版をここに埋め込み予定
      </div>
      {/* TODO: WASM 版を <iframe> / <canvas> で埋め込み。reflectorbit.pages.dev のビルドを利用 */}
    </section>

    {/* ===== Download ===== */}
    <section class="border-t border-white/5 py-24">
      <p class="eyebrow">Download</p>
      <h2 class="mt-3 text-3xl font-bold text-rb-muted sm:text-4xl">ネイティブ版</h2>
      <ul class="mt-8 grid gap-4 sm:grid-cols-3">
        {
          downloads.map((d) => (
            <li class="rounded-lg border border-white/10 p-5">
              <p class="font-semibold text-rb-muted">{d.os}</p>
              <p class="mt-1 font-mono text-sm break-all text-rb-muted/60">{d.file}</p>
            </li>
          ))
        }
      </ul>
      <a class="btn-primary mt-8 inline-block" href={DOWNLOAD_URL}>最新リリースを見る</a>
      <p class="mt-4 text-sm text-rb-muted/70">
        ※ 配布バイナリは未署名のため初回起動時に OS 警告が出る場合がある（手順は本体 README 参照）。
      </p>
    </section>

    {/* ===== Footer ===== */}
    <footer class="border-t border-white/5 py-12 text-sm text-rb-muted/60">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <p>制作: keroway</p>
        <nav class="flex gap-6">
          <a class="hover:text-rb-core" href={REPO_URL}>ゲーム本体リポジトリ</a>
          <a class="hover:text-rb-core" href={PLAY_URL}>ブラウザで遊ぶ</a>
        </nav>
      </div>
    </footer>
  </main>
</Layout>
