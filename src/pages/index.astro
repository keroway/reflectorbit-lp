---
import Concept from '../components/Concept.astro';
import Download from '../components/Download.astro';
import Hero from '../components/Hero.astro';
import HowToPlay from '../components/HowToPlay.astro';
import PlayableDemo from '../components/PlayableDemo.astro';
import Screenshots from '../components/Screenshots.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteNav from '../components/SiteNav.astro';
import Trailer from '../components/Trailer.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <SiteNav />
  <main id="main-content" class="mx-auto max-w-5xl px-6">
    <Hero />
    <Concept />
    <Trailer />
    <Screenshots />
    <HowToPlay />
    <PlayableDemo />
    <Download />
    <SiteFooter />
  </main>
</Layout>

<script>
  // スクロール連動 fade-in。reduced-motion 時は CSS 側で即表示になるため、ここでは一律に観測する。
  const targets = document.querySelectorAll('.reveal');
  if (targets.length > 0 && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            obs.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.12 },
    );
    for (const el of targets) {
      observer.observe(el);
    }
  } else {
    // IntersectionObserver 非対応環境では全件即表示
    for (const el of targets) {
      el.classList.add('is-visible');
    }
  }
</script>
